DATABASE_URL=postgresql://postgres.[project-ref]:[db-password]@[pooler-host]:5432/postgres?sslmode=require
# Optional local-only escape hatch if your network/AV injects a self-signed TLS chain.
# Leave this unset in production so certificate verification stays enabled.
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
SESSION_SECRET=replace-with-a-long-random-secret

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

MEDIA_STORAGE_BACKEND=supabase
SUPABASE_MEDIA_BUCKET=media
# Optional explicit public base URL for a public bucket:
# https://your-project-ref.supabase.co/storage/v1/object/public/media
SUPABASE_MEDIA_PUBLIC_BASE_URL=

APP_BASE_URL=https://your-app-domain.com
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=Tembea Bila Matata <noreply@your-domain.com>
# Optional: force OTP bypass outside localhost/private-network testing in non-production.
# LOCAL_OTP_BYPASS=true
NOTIFICATION_EMAILS=ops@example.com,bookings@example.com

WEB_PUSH_VAPID_PUBLIC_KEY=your-web-push-public-key
WEB_PUSH_VAPID_PRIVATE_KEY=your-web-push-private-key
WEB_PUSH_VAPID_SUBJECT=mailto:you@example.com

ADMIN_EMAILS=admin@example.com
# Optional bootstrap admin login for new production environments:
# ADMIN_BOOTSTRAP_EMAIL=admin@example.com
# ADMIN_BOOTSTRAP_NAME=Tembea Admin
# ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-strong-password
